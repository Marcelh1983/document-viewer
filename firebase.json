{
  "hosting": [
    {
      "target": "demo-angular",
      "public": "dist/apps/demo-angular/browser",
      "predeploy": ["pnpm build:demo-angular"],
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "demo-react",
      "public": "dist/apps/demo-react",
      "predeploy": ["vite build --config apps/demo-react/vite.config.ts"],
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ]
}
