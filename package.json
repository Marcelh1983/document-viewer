{
  "name": "document-viewer",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build:docviewhelper": "pnpm --filter docviewhelper build && node tools/prepare-dist.mjs docviewhelper",
    "build:ngx-doc-viewer": "pnpm --filter ngx-doc-viewer build && node tools/prepare-dist.mjs ngx-doc-viewer",
    "build:react-documents": "pnpm --filter react-documents build && node tools/prepare-dist.mjs react-documents",
    "build:all": "pnpm build:docviewhelper && pnpm build:ngx-doc-viewer && pnpm build:react-documents",
    "build:demo-angular": "ng build demo-angular --configuration production",
    "start:demo:angular": "ng serve demo-angular --port=4200",
    "start:demo:react": "vite --config apps/demo-react/vite.config.ts",
    "test": "jest",
    "lint": "eslint .",
    "publish:docviewhelper": "pnpm build:docviewhelper && npm publish ./dist/packages/docviewhelper --tag latest",
    "publish:react-documents": "pnpm build:react-documents && npm publish ./dist/packages/react-documents --tag latest",
    "publish:react-documents:next": "pnpm build:react-documents && npm publish ./dist/packages/react-documents --tag next",
    "publish:ngx-doc-viewer": "pnpm build:ngx-doc-viewer && npm publish ./dist/packages/ngx-doc-viewer --tag latest",
    "publish:ngx-doc-viewer:next": "pnpm build:ngx-doc-viewer && npm publish ./dist/packages/ngx-doc-viewer --tag next",
    "publish:all": "pnpm publish:docviewhelper && pnpm publish:ngx-doc-viewer && pnpm publish:react-documents",
    "version:patch": "node tools/bump-version.mjs patch",
    "version:minor": "node tools/bump-version.mjs minor",
    "version:major": "node tools/bump-version.mjs major",
    "deploy:demo:angular": "firebase use angular-doc-viewer && firebase deploy --only hosting:demo-angular",
    "deploy:demo:react": "firebase use angular-doc-viewer && firebase deploy --only hosting:demo-react"
  },
  "private": true,
  "devDependencies": {
    "@angular-devkit/build-angular": "~21.2.2",
    "@angular-devkit/schematics": "~21.2.2",
    "@angular/cli": "~21.2.2",
    "@angular/compiler-cli": "~21.2.4",
    "@angular/language-service": "~21.2.4",
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-react": "^7.26.0",
    "@babel/preset-typescript": "^7.26.0",
    "@schematics/angular": "~21.2.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "angular-eslint": "^21.3.0",
    "babel-jest": "^29.7.0",
    "eslint": "^10.0.3",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-preset-angular": "^16.1.1",
    "ng-packagr": "~21.2.0",
    "rimraf": "^6.0.0",
    "sass": "^1.83.0",
    "tailwindcss": "^4.2.1",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsup": "^8.3.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@angular-devkit/architect": "~0.2102.2",
    "@angular-devkit/core": "~21.2.2",
    "@angular/animations": "~21.2.4",
    "@angular/common": "~21.2.4",
    "@angular/compiler": "~21.2.4",
    "@angular/core": "~21.2.4",
    "@angular/forms": "~21.2.4",
    "@angular/platform-browser": "~21.2.4",
    "@angular/platform-browser-dynamic": "~21.2.4",
    "@angular/router": "~21.2.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.0",
    "zone.js": "~0.16.1"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
