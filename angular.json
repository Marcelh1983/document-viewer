{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "demo-angular": {
      "projectType": "application",
      "schematics": {},
      "root": "apps/demo-angular",
      "sourceRoot": "apps/demo-angular/src",
      "prefix": "document-viewer",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/apps/demo-angular",
            "index": "apps/demo-angular/src/index.html",
            "browser": "apps/demo-angular/src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "apps/demo-angular/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "apps/demo-angular/src/assets",
                "output": "assets"
              },
              {
                "glob": "favicon.ico",
                "input": "apps/demo-angular/src",
                "output": ""
              }
            ],
            "styles": ["apps/demo-angular/src/styles.scss"],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kb",
                  "maximumError": "1mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "2kb",
                  "maximumError": "4kb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "apps/demo-angular/src/environments/environment.ts",
                  "with": "apps/demo-angular/src/environments/environment.prod.ts"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "demo-angular:build:production"
            },
            "development": {
              "buildTarget": "demo-angular:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n"
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
