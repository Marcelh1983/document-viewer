{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "types": ["node"],
    "skipLibCheck": true,
    "declaration": true,
    "baseUrl": ".",
    "paths": {
      "docviewhelper": ["../../dist/packages/docviewhelper"]
    }
  },
  "exclude": [
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/*.spec.tsx",
    "**/*.test.tsx",
    "**/*.spec.js",
    "**/*.test.js",
    "**/*.spec.jsx",
    "**/*.test.jsx",
    "jest.config.ts"
  ],
  "include": ["src/**/*"]
}
